# Moments — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# --- Database: Neon Postgres ---
# Pooled connection string from the Neon dashboard (use the "Pooled connection").
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/moments?sslmode=require

# --- Auth: Clerk (email magic link) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Route Clerk's flows and post-auth landing (spec: land on /stories).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/stories
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/stories

# --- Storage: Vercel Blob (audio + photos) ---
# Create a Blob store in the Vercel dashboard; token is read-write.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# --- Transcription (word-level timestamps required) ---
DEEPGRAM_API_KEY=your-deepgram-key

# --- LLM (interviewer, extraction, structuring, polishing) ---
ANTHROPIC_API_KEY=your-anthropic-key

# --- Email notifications (story viewed, reaction received) ---
RESEND_API_KEY=your-resend-key

# --- App ---
# Base URL used to build shareable /s/{token} links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
