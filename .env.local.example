# Moments — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# --- Supabase (auth, database, storage) ---
# Project URL and anon key are safe to expose to the browser; RLS protects data.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key bypasses RLS — SERVER ONLY. Used for share-token routes and
# cascade deletes. Never prefix with NEXT_PUBLIC_ and never send to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Transcription (word-level timestamps required) ---
# Deepgram Nova is the default; swap for OpenAI Whisper + alignment if preferred.
DEEPGRAM_API_KEY=your-deepgram-key

# --- LLM (interviewer, extraction, structuring, polishing) ---
ANTHROPIC_API_KEY=your-anthropic-key

# --- Email notifications (story viewed, reaction received) ---
RESEND_API_KEY=your-resend-key

# --- App ---
# Base URL used to build shareable /s/{token} links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
